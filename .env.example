# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Admin Panel
ADMIN_SECRET=your-admin-secret-min-32-chars

# Resend (E-posta)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=bilgi@kismetplastik.com

# OpenAI (Chatbot - opsiyonel)
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# Google Translate API (opsiyonel — otomatik çeviri için)
GOOGLE_TRANSLATE_API_KEY=

# Google Analytics (opsiyonel)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Supabase Service Role (sunucu tarafı admin işlemleri)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# DIA ERP Entegrasyonu (opsiyonel — stok/müşteri senkronizasyonu)
DIA_API_URL=https://your-dia-server/api/v3
DIA_API_KEY=your-dia-api-key
DIA_USERNAME=your-dia-username
DIA_PASSWORD=your-dia-password
DIA_FIRMA_KODU=your-firma-kodu
DIA_DONEM_KODU=your-donem-kodu

# Halkbank POS (opsiyonel — ödeme sistemi)
HALKBANK_MERCHANT_ID=your-merchant-id
HALKBANK_STORE_KEY=your-store-key
HALKBANK_TERMINAL_ID=your-terminal-id

# Cron Jobs
CRON_SECRET=your-cron-secret-min-32-chars

# Site URL
NEXT_PUBLIC_BASE_URL=https://www.kismetplastik.com
